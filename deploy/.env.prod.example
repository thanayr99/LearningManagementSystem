# Domain serving the backend API (A record to your droplet IP)
BACKEND_DOMAIN=api.yourdomain.com

# MySQL
MYSQL_DB=iawes_db
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET
JWT_EXPIRATION_MS=86400000

# CORS must include your frontend production URL
CORS_ALLOWED_ORIGINS=https://learning-management-system-pi-three.vercel.app,https://your-frontend-domain.vercel.app
